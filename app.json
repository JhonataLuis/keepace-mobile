{
  "expo": {
    "name": "keepeace-mobile",
    "slug": "keepeace-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-keepace.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/icon-keepace.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
       "bundleIdentifier": "com.openfonte.keepeacemobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-keepace.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.openfonte.keepeacemobile",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/keepace.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-keepace.png",
          "color": "#ffffff",
          "sounds": ["./assets/sounds/notification.wav"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "993e6439-0ea3-4413-9a8d-4520cd8c4f02"
      }
    },
     "notification": {
      "icon": "./assets/icon-keepace.png",
      "color": "#ffffff",
      "androidMode": "default",
      "androidCollapsedTitle": "KeeePace"
    }
  }
}
